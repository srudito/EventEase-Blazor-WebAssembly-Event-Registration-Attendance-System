@inherits LayoutComponentBase

<div class="main-layout d-flex flex-column" style="min-height:100vh;">

    <!-- Top Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm px-4">
        <a class="navbar-brand fw-bold text-primary" href="/">EventEase</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="mainNav">
            <ul class="navbar-nav">
                @* Changed ms-3 to ms-lg-3 for better mobile alignment *@
                <li class="nav-item ms-lg-3">
                    <NavLink class="nav-link" href="about">About</NavLink>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-fill">
        <div class="container py-4">
            @Body
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer bg-light text-center py-3 border-top mt-auto">
        <small class="text-muted">
            © @DateTime.Now.Year EventEase — All rights reserved.
        </small>
    </footer>

</div>